<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp"
    app:cardForegroundColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- Top trip image with overlay badges                                  -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAdventureImage"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_adventure_image"
                android:contentDescription="@string/cd_adventure_image"
                app:shapeAppearance="@style/ShapeAppearance.TravellBuddy.RoundedImage" />

            <!-- HOSTED badge - teal color (top-left) -->
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_badge_hosted_teal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/role_hosted"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <!-- Location icon (bottom-right of image) -->
            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_location_button_dark">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_location_pin"
                    app:tint="@color/white"
                    android:contentDescription="@null" />
            </FrameLayout>

        </FrameLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- Content section below image                                         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Title and Price row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#1E293B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginEnd="12dp"
                    tools:text="Weekend in Paris" />

                <!-- Price pill -->
                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_price_pill_teal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:textColor="#0D9488"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="€ 350" />
            </LinearLayout>

            <!-- Date and Joined row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Date with orange calendar icon -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar_orange"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="#64748B"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        tools:text="Oct 10 - Oct 14" />
                </LinearLayout>

                <!-- Joined count with blue people icon -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_people_blue"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvJoined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="#64748B"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        tools:text="0/4 joined" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

