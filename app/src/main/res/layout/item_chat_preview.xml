<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- Avatar with online indicator -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@color/divider"
                android:clickable="true"
                android:focusable="true"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.TravellBuddy.Circle"
                tools:src="@tools:sample/avatars" />

            <!-- Online indicator -->
            <View
                android:id="@+id/onlineIndicator"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_online_indicator"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <!-- Name and Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Alex Johnson" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    tools:text="10:42 AM" />
            </LinearLayout>

            <!-- Message preview and unread badge row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvLastMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="Sounds great! See you at the trailhead" />

                <!-- Unread count badge -->
                <TextView
                    android:id="@+id/tvUnreadCount"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_unread_badge"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="2"
                    tools:visibility="visible" />

                <!-- Unread dot indicator (blue dot for new messages) -->
                <View
                    android:id="@+id/unreadDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_notification_dot"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- Read indicator (checkmark) -->
                <ImageView
                    android:id="@+id/ivReadIndicator"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_check_circle"
                    android:visibility="gone"
                    app:tint="@color/text_hint"
                    android:contentDescription="@null"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- Trip type label -->
            <TextView
                android:id="@+id/tvTripType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                tools:text="ALPINE LAKE HIKING" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="90dp"
        android:background="@color/divider_light" />

</LinearLayout>
