{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$uid": {
        ".validate": "newData.isBoolean()"
      }
    },
    "users": {
      ".indexOn": ["email", "displayName", "isBanned", "role", "createdAt"],
      ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$uid": {
        ".read": "auth != null",
        ".write": "(auth != null && auth.uid == $uid) || (auth != null && root.child('admins').child(auth.uid).val() == true)",
        ".validate": "newData.hasChildren(['uid', 'displayName', 'email', 'createdAt'])",
        "uid": {
          ".validate": "newData.val() == $uid"
        },
        "role": {
          ".validate": "newData.isString() && (newData.val() == 'user' || newData.val() == 'admin')",
          ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
        },
        "isBanned": {
          ".validate": "newData.isBoolean()",
          ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
        },
        "isVerified": {
          ".validate": "newData.isBoolean() && (auth.uid == $uid ? newData.val() == false || data.val() == newData.val() : root.child('admins').child(auth.uid).val() == true)"
        },
        "ratingSummary": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['averageRating', 'totalRatings'])",
          "averageRating": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
          },
          "totalRatings": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        },
        "tripCounters": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['tripsAsDriver', 'tripsAsRider'])",
          "tripsAsDriver": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "tripsAsRider": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "fcmToken": {
          ".validate": "newData.isString()"
        }
      }
    },
    "trips": {
      ".read": "auth != null",
      ".indexOn": ["departureTime", "driverUid", "status", "originCity", "destinationCity", "createdAt"],
      "$tripId": {
        ".write": "auth != null && (!data.exists() || data.child('driverUid').val() == auth.uid || root.child('admins').child(auth.uid).val() == true)",
        ".validate": "!newData.exists() || newData.hasChildren(['tripId', 'driverUid', 'driverName', 'originCity', 'destinationCity', 'departureTime', 'availableSeats', 'totalSeats', 'pricePerSeat', 'status', 'createdAt'])",
        "tripId": {
          ".validate": "!newData.exists() || newData.val() == $tripId"
        },
        "driverUid": {
          ".validate": "!newData.exists() || (newData.isString() && (!data.exists() || newData.val() == data.val()))"
        },
        "departureTime": {
          ".validate": "!newData.exists() || (newData.isNumber() && (!data.exists() ? newData.val() > now : true))"
        },
        "availableSeats": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= newData.parent().child('totalSeats').val())"
        },
        "totalSeats": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 20)"
        },
        "pricePerSeat": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "status": {
          ".validate": "!newData.exists() || (newData.isString() && (newData.val() == 'open' || newData.val() == 'full' || newData.val() == 'in_progress' || newData.val() == 'completed' || newData.val() == 'canceled'))"
        },
        "createdAt": {
          ".validate": "!newData.exists() || (newData.isNumber() && (!data.exists() || newData.val() == data.val()))"
        },
        "originLat": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -90 && newData.val() <= 90)"
        },
        "originLng": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -180 && newData.val() <= 180)"
        },
        "destLat": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -90 && newData.val() <= 90)"
        },
        "destLng": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -180 && newData.val() <= 180)"
        },
        "participants": {
          "$participantUid": {
            ".write": "auth != null && (root.child('trips').child($tripId).child('driverUid').val() == auth.uid || root.child('admins').child(auth.uid).val() == true)",
            ".validate": "!newData.exists() || newData.isBoolean()"
          }
        }
      }
    },
    "tripRequests": {
      "$tripId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["riderUid", "status", "createdAt"],
        "$requestId": {
          ".validate": "newData.hasChildren(['requestId', 'tripId', 'riderUid', 'status', 'seatsRequested', 'createdAt'])"
        }
      }
    },
    "tripMembers": {
      "$tripId": {
        ".read": "auth != null && (root.child('trips').child($tripId).child('driverUid').val() == auth.uid || data.child(auth.uid).exists() || root.child('admins').child(auth.uid).val() == true)",
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && (root.child('trips').child($tripId).child('driverUid').val() == auth.uid || root.child('admins').child(auth.uid).val() == true)",
          ".validate": "newData.hasChildren(['uid', 'role', 'joinedAt', 'seatsOccupied'])",
          "uid": {
            ".validate": "newData.val() == $uid"
          },
          "role": {
            ".validate": "newData.isString() && (newData.val() == 'driver' || newData.val() == 'rider')"
          },
          "joinedAt": {
            ".validate": "newData.isNumber()"
          },
          "seatsOccupied": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 4"
          }
        }
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null && (data.child('participants').child(auth.uid).val() == true || data.child('info').child('participants').child(auth.uid).val() == true || root.child('admins').child(auth.uid).val() == true)",
        ".write": "auth != null && (data.child('participants').child(auth.uid).val() == true || data.child('info').child('participants').child(auth.uid).val() == true || newData.child('participants').child(auth.uid).val() == true || newData.child('info').child('participants').child(auth.uid).val() == true || !data.exists() || root.child('admins').child(auth.uid).val() == true)",
        "participants": {
          "$participantUid": {
            ".validate": "newData.isBoolean()"
          }
        },
        "info": {
          ".validate": "newData.hasChildren(['chatId', 'tripId', 'name', 'createdBy']) && newData.child('participants').child(auth.uid).val() == true",
          "participants": {
            "$participantUid": {
              ".validate": "newData.isBoolean()"
            }
          }
        },
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['messageId', 'senderUid', 'text', 'timestamp'])",
            "messageId": {
              ".validate": "newData.isString()"
            },
            "senderUid": {
              ".validate": "newData.isString() && newData.val() == auth.uid"
            },
            "senderName": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            }
          }
        },
        "lastMessage": {
          ".validate": "newData.isString()"
        },
        "lastMessageTime": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "userChats": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).val() == true)",
        ".write": "auth != null",
        ".indexOn": ["lastMessageTime"],
        "$chatId": {
          ".validate": "newData.hasChildren(['chatId', 'lastMessageTime']) && (newData.hasChild('otherPartyUid') || newData.hasChild('isGroupChat'))"
        }
      }
    },
    "ratings": {
      ".read": "auth != null",
      "$tripId": {
        ".read": "auth != null",
        ".indexOn": ["revieweeUid", "reviewerUid", "createdAt"],
        "$ratingId": {
          ".write": "auth != null && (!data.exists() && $ratingId.contains(auth.uid) || root.child('admins').child(auth.uid).val() == true)",
          ".validate": "newData.hasChildren(['ratingId', 'tripId', 'reviewerUid', 'revieweeUid', 'score', 'createdAt']) && newData.child('reviewerUid').val() == auth.uid",
          "ratingId": {
            ".validate": "newData.isString()"
          },
          "tripId": {
            ".validate": "newData.val() == $tripId"
          },
          "reviewerUid": {
            ".validate": "newData.isString() && newData.val() == auth.uid"
          },
          "revieweeUid": {
            ".validate": "newData.isString() && newData.val() != auth.uid"
          },
          "score": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5 && newData.val() % 1 === 0.0"
          },
          "createdAt": {
            ".validate": "newData.isNumber() && newData.val() <= now"
          },
          "comment": {
            ".validate": "!newData.exists() || newData.isString()"
          },
          "reviewerName": {
            ".validate": "!newData.exists() || newData.isString()"
          },
          "isEditable": {
            ".validate": "!newData.exists() || newData.isBoolean()"
          }
        }
      }
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
      ".indexOn": ["reporterUid", "reportedUid", "status"],
      "$reportId": {
        ".write": "(auth != null && !data.exists()) || (auth != null && root.child('admins').child(auth.uid).val() == true)",
        ".validate": "newData.hasChildren(['reportId', 'reporterUid', 'reportedUid', 'reason', 'createdAt', 'status'])",
        "reportId": {
          ".validate": "newData.isString()"
        },
        "reporterUid": {
          ".validate": "newData.isString() && newData.val() == auth.uid"
        },
        "reportedUid": {
          ".validate": "newData.isString() && newData.val() != auth.uid"
        },
        "reason": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "description": {
          ".validate": "newData.isString() && newData.val().length <= 2000"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'open' || (root.child('admins').child(auth.uid).val() == true && (newData.val() == 'reviewed' || newData.val() == 'resolved')))"
        }
      }
    },
    "notifications": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || root.child('admins').child(auth.uid).val() == true)",
        ".write": "auth != null",
        "$notificationId": {
          ".validate": "newData.hasChildren(['type', 'createdAt'])"
        }
      },
      "send": {
        ".read": "auth != null && root.child('admins').child(auth.uid).val() == true",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
      }
    },
    "announcements": {
      ".read": "auth != null",
      ".indexOn": ["createdAt", "isActive"],
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$announcementId": {
        ".validate": "newData.hasChildren(['announcementId', 'title', 'message', 'createdAt', 'isActive'])"
      }
    },
    "categories": {
      ".read": "auth != null",
      ".indexOn": ["order", "isActive"],
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$categoryId": {
        ".validate": "newData.hasChildren(['categoryId', 'name', 'isActive'])"
      }
    },
    "featuredTrips": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true",
      "$tripId": {
        ".validate": "newData.hasChildren(['tripId', 'featuredAt'])"
      }
    }
  }
}
