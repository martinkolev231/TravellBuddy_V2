<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/welcome_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cd_adventure_image"
        tools:background="#3D4A5D" />

    <!-- Dark gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_welcome_overlay" />

    <!-- Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false">

        <!-- Welcome badge -->
        <TextView
            android:id="@+id/tvWelcomeTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_welcome_badge"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/welcome_to"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintBottom_toTopOf="@id/tvAppTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="16dp" />

        <!-- App title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/welcome_title"
            android:textColor="@color/white"
            android:textSize="44sp"
            android:textStyle="bold|italic"
            android:fontFamily="serif"
            android:maxLines="1"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="28sp"
            app:autoSizeMaxTextSize="44sp"
            app:autoSizeStepGranularity="2sp"
            app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/welcome_subtitle"
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.4"
            app:layout_constraintBottom_toTopOf="@id/btnSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="32dp"
            android:layout_marginEnd="48dp" />

        <!-- Sign Up button -->
        <LinearLayout
            android:id="@+id/btnSignUp"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_signup_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:elevation="8dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:layout_constraintBottom_toTopOf="@id/btnLogIn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_sign_up_welcome"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_arrow_forward"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Log In button -->
        <TextView
            android:id="@+id/btnLogIn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_login_button"
            android:gravity="center"
            android:text="@string/btn_log_in_welcome"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>




