<?xml version="1.0" encoding="utf-8"?>
<!-- Chat bubble: sent — right-aligned, Primary color, 18dp corners except bottom-right 4dp -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/chat_bubble_sent" />
    <corners
        android:topLeftRadius="@dimen/chat_bubble_corner"
        android:topRightRadius="@dimen/chat_bubble_corner"
        android:bottomLeftRadius="@dimen/chat_bubble_corner"
        android:bottomRightRadius="@dimen/chat_bubble_corner_tail" />
    <padding
        android:left="@dimen/chat_bubble_padding_h"
        android:top="@dimen/chat_bubble_padding_v"
        android:right="@dimen/chat_bubble_padding_h"
        android:bottom="@dimen/chat_bubble_padding_v" />
</shape>
