    android:shape="rectangle">
    <solid android:color="@color/trip_card_accent" />
    <size android:width="@dimen/trip_card_accent_width" />
    <corners
        android:topLeftRadius="@dimen/trip_card_corner_radius"
        android:bottomLeftRadius="@dimen/trip_card_corner_radius"
        android:topRightRadius="0dp"
        android:bottomRightRadius="0dp" />
</shape>

