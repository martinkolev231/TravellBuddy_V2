<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Adventure cover image with badges ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAdventureImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_adventure_image"
                android:contentDescription="@string/cd_adventure_image"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.TravellBuddy.CardImageTop" />

            <!-- ONLY X SPOTS LEFT badge - coral/red color -->
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_badge_spots_left"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                tools:text="ONLY 1 SPOTS LEFT" />

            <!-- Organizer profile photo - top right with white border -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivOrganizerPhoto"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="14dp"
                android:scaleType="centerCrop"
                android:background="@color/white"
                android:padding="2dp"
                android:clickable="true"
                android:focusable="true"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.TravellBuddy.Circle"
                app:strokeColor="@color/white"
                app:strokeWidth="3dp"
                android:contentDescription="Organizer"
                tools:visibility="visible" />

            <!-- Save/Bookmark button - hidden when organizer photo is shown -->
            <FrameLayout
                android:id="@+id/btnSave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_save_button_subtle"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivSaveIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_bookmark_outline"
                    app:tint="@color/white"
                    android:contentDescription="Save" />
            </FrameLayout>

            <!-- Location pin icon - bottom right -->
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_location_pin_dark">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_location_pin"
                    app:tint="@color/white"
                    android:contentDescription="@null" />
            </FrameLayout>

        </FrameLayout>

        <!-- ── Card content ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <!-- Title and Price row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginBottom="12dp">

                <!-- Title - can be 2 lines -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginEnd="12dp"
                    tools:text="West Coast Surf &amp; Road Trip" />

                <!-- Price badge -->
                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_price_badge_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="€ 300" />
            </LinearLayout>

            <!-- Date and Joined row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar_outline"
                        app:tint="#9CA3AF"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="Sep 01 - Sep 10" />
                </LinearLayout>

                <!-- Joined count -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_people"
                        app:tint="#9CA3AF"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tvJoined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        tools:text="2/3 joined" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
