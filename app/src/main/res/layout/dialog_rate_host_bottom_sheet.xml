<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical"
    android:paddingBottom="@dimen/spacing_xl">

    <!-- Drag handle -->
    <View
        android:layout_width="@dimen/bottom_sheet_drag_handle_width"
        android:layout_height="@dimen/bottom_sheet_drag_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Close button (top-right) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_lg"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary" />
    </FrameLayout>

    <!-- Host Avatar with Star Badge -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="4dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivHostAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp"
            tools:src="@drawable/bg_profile_placeholder" />

        <!-- Star badge overlay (bottom-right) -->
        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-4dp"
            android:layout_marginBottom="-4dp"
            android:background="@drawable/bg_star_badge">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_star_filled"
                app:tint="@android:color/white" />
        </FrameLayout>
    </FrameLayout>

    <!-- Title: Rate [Host Name] -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_lg"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="Rate Alex Johnson" />

    <!-- Subtitle: Trip: [Trip Name] -->
    <TextView
        android:id="@+id/tvTripName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_xs"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        tools:text="Trip: Weekend Hiking in the Alps" />

    <!-- Question: How was your experience? -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/label_rate_experience_question"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 5 Interactive Stars -->
    <LinearLayout
        android:id="@+id/starsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_lg"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/cd_star_1"
            android:padding="4dp"
            android:src="@drawable/ic_star_empty"
            app:tint="@color/star_empty_rating" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/cd_star_2"
            android:padding="4dp"
            android:src="@drawable/ic_star_empty"
            app:tint="@color/star_empty_rating" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/cd_star_3"
            android:padding="4dp"
            android:src="@drawable/ic_star_empty"
            app:tint="@color/star_empty_rating" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/cd_star_4"
            android:padding="4dp"
            android:src="@drawable/ic_star_empty"
            app:tint="@color/star_empty_rating" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="@string/cd_star_5"
            android:padding="4dp"
            android:src="@drawable/ic_star_empty"
            app:tint="@color/star_empty_rating" />
    </LinearLayout>

    <!-- Optional Review Text Field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilReview"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_xl"
        android:layout_marginTop="@dimen/spacing_xl"
        android:hint="@string/hint_review_optional"
        app:boxCornerRadiusBottomEnd="@dimen/radius_md"
        app:boxCornerRadiusBottomStart="@dimen/radius_md"
        app:boxCornerRadiusTopEnd="@dimen/radius_md"
        app:boxCornerRadiusTopStart="@dimen/radius_md"
        app:boxStrokeColor="@color/input_stroke_focused"
        app:hintTextColor="@color/text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="500"
            android:maxLines="4"
            android:minLines="3"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Submit Rating Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitRating"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="@dimen/spacing_xl"
        android:layout_marginTop="@dimen/spacing_xl"
        android:enabled="false"
        android:text="@string/btn_submit_rating"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/button_disabled_bg"
        app:cornerRadius="100dp" />

</LinearLayout>

