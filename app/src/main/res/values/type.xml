<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════════════════════════════════════════════════
         Typography System — Plus Jakarta Sans + DM Sans
         ════════════════════════════════════════════════ -->

    <!-- ── Display ── -->
    <style name="TextAppearance.TravellBuddy.Display.Large" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Display.Medium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">sans-serif-bold</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- ── Headline ── -->
    <style name="TextAppearance.TravellBuddy.Headline.Large" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif-bold</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Headline.Medium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Headline.Small" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Title ── -->
    <style name="TextAppearance.TravellBuddy.Title.Large" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Title.Medium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Title.Small" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Body (DM Sans) ── -->
    <style name="TextAppearance.TravellBuddy.Body.Large" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Body.Medium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Body.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <!-- ── Label ── -->
    <style name="TextAppearance.TravellBuddy.Label.Large" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Label.Medium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Label.Small" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- ── Button text ── -->
    <style name="TextAppearance.TravellBuddy.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Button.Small" parent="TextAppearance.TravellBuddy.Button">
        <item name="android:textSize">14sp</item>
    </style>

    <!-- ── Chat message text ── -->
    <style name="TextAppearance.TravellBuddy.Chat.Message" parent="TextAppearance.TravellBuddy.Body.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Chat.Timestamp" parent="TextAppearance.TravellBuddy.Label.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- ── Trip card specific ── -->
    <style name="TextAppearance.TravellBuddy.TripCard.Route" parent="TextAppearance.TravellBuddy.Title.Medium">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.TravellBuddy.TripCard.Detail" parent="TextAppearance.TravellBuddy.Body.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.TravellBuddy.TripCard.Price" parent="TextAppearance.TravellBuddy.Title.Large">
        <item name="fontFamily">sans-serif-bold</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- ── Navigation / Toolbar ── -->
    <style name="TextAppearance.TravellBuddy.Toolbar.Title" parent="TextAppearance.TravellBuddy.Headline.Medium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Chip / Badge ── -->
    <style name="TextAppearance.TravellBuddy.Chip" parent="TextAppearance.TravellBuddy.Label.Medium">
        <item name="android:textSize">12sp</item>
    </style>

    <!-- ── Form input ── -->
    <style name="TextAppearance.TravellBuddy.Input" parent="TextAppearance.TravellBuddy.Body.Medium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.TravellBuddy.Input.Hint" parent="TextAppearance.TravellBuddy.Body.Medium">
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <!-- ── Rating ── -->
    <style name="TextAppearance.TravellBuddy.Rating.Score" parent="TextAppearance.TravellBuddy.Display.Medium">
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Splash Wordmark ── -->
    <style name="TextAppearance.TravellBuddy.Splash.Wordmark" parent="TextAppearance.TravellBuddy.Display.Medium">
        <item name="fontFamily">sans-serif-black</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>

